# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://gym:gym@127.0.0.1:55432/gym_pt?schema=public"
# Locally the direct URL is the same as DATABASE_URL (only differs on Neon/serverless).
DIRECT_URL="postgresql://gym:gym@127.0.0.1:55432/gym_pt?schema=public"

# Auth — CHANGE THIS in production to a long random string
AUTH_SECRET="dev-secret-change-me-to-a-long-random-string-please-1234567890"

# --- Optional: email reminders (nodemailer). If unset, reminder emails are
#     logged to the server console instead of being sent. ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="apikey-or-username"
# SMTP_PASS="your-smtp-password"
# EMAIL_FROM="CoachDeck <no-reply@yourgym.com>"

# --- Optional: secret required to call the reminder dispatch cron endpoint
#     (POST /api/sync/reminders/dispatch with header x-cron-secret). Required in production. ---
# CRON_SECRET="set-a-long-random-value"
