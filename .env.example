# ---------------------------------------------------------------------------
# Copy to .env for local dev, or set these as Environment Variables in Vercel.
# ---------------------------------------------------------------------------

# Postgres. On Neon use the POOLED connection string (host contains "-pooler")
# with ?sslmode=require for DATABASE_URL, and the DIRECT (non-pooler) string for DIRECT_URL.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Session signing secret. Generate with:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Progress photo storage. On Vercel, add a Blob store and this is set automatically.
# Leave unset locally to store photos under public/uploads instead.
BLOB_READ_WRITE_TOKEN=""

# Secret for the reminder dispatch endpoint. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>" automatically when this is set.
CRON_SECRET="change-me-to-a-long-random-string"

# Optional: real email delivery for reminders (otherwise they log to the console).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="CoachDeck <no-reply@yourgym.com>"
